ADMIN_APP_NEIGHBORHOOD=Sistema

EMAIL_VERIFICATION_TOKEN_DURATION=24h
PASSWORD_RESET_TOKEN_DURATION=30m

DENUNCIA_ANEXOS_DIR=uploads/denuncias
DENUNCIA_ANEXOS_MAX_FILE_SIZE=10MB
DENUNCIA_ANEXOS_MAX_REQUEST_SIZE=12MB
DENUNCIA_ANEXOS_MAX_BYTES=10485760
